---
// src/pages/outils-methodes.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Outils & Méthodes — Physique-Chimie" description="Formulaires, convertisseur, calculatrice et méthodes de résolution pour le collège et le lycée.">
  <div style="text-align:center; padding: 3rem 1rem;">
    <span style="font-size:3rem;">📐</span>
    <h1 style="font-size:1.6rem; font-weight:800; color:var(--accent-primary); margin:0.5rem 0;">Outils & Méthodes</h1>
    <p style="color:var(--text-muted); font-size:1rem; margin-bottom:2rem;">Formulaires, convertisseur, calculatrice et méthodes de résolution.</p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:1rem; max-width:700px; margin:0 auto;">
      <div class="card" style="padding:1.5rem; text-align:center; opacity:0.5;">
        <span style="font-size:2rem;">🔢</span>
        <p style="font-weight:600; margin-top:0.5rem;">Calculatrice</p>
        <span style="font-size:0.75rem; color:var(--accent-warning);">À venir</span>
      </div>
      <div class="card" style="padding:1.5rem; text-align:center; opacity:0.5;">
        <span style="font-size:2rem;">📏</span>
        <p style="font-weight:600; margin-top:0.5rem;">Convertisseur</p>
        <span style="font-size:0.75rem; color:var(--accent-warning);">À venir</span>
      </div>
      <div class="card" style="padding:1.5rem; text-align:center; opacity:0.5;">
        <span style="font-size:2rem;">📋</span>
        <p style="font-weight:600; margin-top:0.5rem;">Formulaires</p>
        <span style="font-size:0.75rem; color:var(--accent-warning);">À venir</span>
      </div>
      <div class="card" style="padding:1.5rem; text-align:center; opacity:0.5;">
        <span style="font-size:2rem;">⚖️</span>
        <p style="font-weight:600; margin-top:0.5rem;">Équilibrage</p>
        <span style="font-size:0.75rem; color:var(--accent-warning);">À venir</span>
      </div>
    </div>
  </div>
</BaseLayout>
