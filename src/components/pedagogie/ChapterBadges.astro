<section class="chapter-badges-card" data-chapter-badges-card>
  <div class="chapter-badges-top">
    <h2>🏅 Exploits du chapitre</h2>
    <p class="chapter-badges-subtitle">
      Les badges se débloquent selon tes réussites sur ce chapitre.
    </p>
  </div>

  <div class="chapter-badges-grid">
    <div class="badge-card" data-badge="perfectQuiz">
      <div class="badge-icon">🎯</div>
      <div class="badge-content">
        <h3>Quiz parfait</h3>
        <p>Obtenir le score maximal au quiz.</p>
      </div>
    </div>

    <div class="badge-card" data-badge="perfectFirstTry">
      <div class="badge-icon">⚡</div>
      <div class="badge-content">
        <h3>Premier essai parfait</h3>
        <p>Réussir un quiz parfait dès la première tentative.</p>
      </div>
    </div>

    <div class="badge-card" data-badge="flashcardsCompleted">
      <div class="badge-icon">🧠</div>
      <div class="badge-content">
        <h3>Flashcards complètes</h3>
        <p>Retourner toutes les flashcards du chapitre.</p>
      </div>
    </div>

    <div class="badge-card" data-badge="chapterMastered">
      <div class="badge-icon">🏆</div>
      <div class="badge-content">
        <h3>Chapitre maîtrisé</h3>
        <p>Quiz parfait + flashcards complètes.</p>
      </div>
    </div>
  </div>
</section>